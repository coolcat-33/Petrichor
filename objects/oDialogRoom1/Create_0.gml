// Inherit the parent event
event_inherited();

dialog.add(artemis_talking, "You made it through the first layer. Impressive, though I expected nothing less.");
dialog.add(artemis_talking, "The deeper you go, the more hostile it gets. The People have had centuries to fortify their tunnels. What you just saw? That was just the beginning.");
dialog.add(artemis_thinking, "My scans are picking up something unusual ahead. Structured walls. Organized patrol routes. They are not just hiding down here, they are thriving.");
dialog.add(artemis_talking, "Stay sharp. The gold is close, and so are they.");
